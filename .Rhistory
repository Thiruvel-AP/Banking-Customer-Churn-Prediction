model.grid = extract_parameter_set_dials(model.workflow) %>%
# update the tune grid parameters
update(
# Number of trees
trees = trees(range = c(10, 1000)),
# learning rate
learn_rate = learn_rate(range = c(0.0005, 0.2)),
# Tree depth
tree_depth = tree_depth(range = c(2, 10)),
# loss
loss_reduction = loss_reduction(range = c(0, 10)),
)
summary(model.grid)
knitr::opts_chunk$set(echo = TRUE)
# Create the XGBoost model and store it in xgboost.model
xgboost.model = boost_tree(
# Number of trees
trees = tune(),
# learning rate
learn_rate = tune(),
# depth of tree
tree_depth = tune(),
# loss
loss_reduction = tune()
) %>%
# Set the mode as classification
set_mode("classification") %>%
# Set the engine as xgboost
set_engine(
"xgboost",
param = list(
# GPU training
tree_method = "gpu_hist",
# GPU inference
predictor   = "gpu_predictor",
# number of threads
nthread = 10
)
)
summary(xgboost.model)
# Create a workflow using workflow() and assign it to model.workflow
model.workflow = workflow() %>%
# Add the recipe
add_recipe(recipe.df) %>%
# Add the model
add_model(xgboost.model)
summary(model.workflow)
# Create a grid using extract_parameter_set_dials() and store it in model.grid
model.grid = extract_parameter_set_dials(model.workflow) %>%
# update the tune grid parameters
update(
# Number of trees
trees = trees(range = c(10, 1000)),
# learning rate
learn_rate = learn_rate(range = c(0.0005, 0.2)),
# Tree depth
tree_depth = tree_depth(range = c(2, 10)),
# loss
loss_reduction = loss_reduction(range = c(0, 10)),
)
summary(model.grid)
# Set the seed
set.seed(seed_value)
# Create a Bayesian Grid CV and store it in bayesian.cv
bayesian.cv = tune_bayes(
# workflow
model.workflow,
# set the fold
resamples = k.fold,
# parameters to tune
param_info = model.grid,
# tuned grid
initial = tune_grid(
# workflow
model.workflow,
# folds
resamples = k.fold,
# Number of grids
grid = 30
),
# Number of iterations
iter = 30,
# metrics
metrics = metric_set(f_meas, roc_auc),
)
knitr::opts_chunk$set(echo = TRUE)
